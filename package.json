{
  "name": "klisp",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "main": "./dist/klisp.umd.cjs",
  "module": "./dist/klisp.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/klisp.js",
      "require": "./dist/klisp.umd.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "vite",
    "build": "tsc && npm run build:lib && npm run build:site",
    "build:site": "vite build -c vite.config.ts --emptyOutDir",
    "build:lib": "vite build -c vite.config.lib.ts",
    "lint": "eslint . --report-unused-disable-directives --max-warnings 0",
    "test": "vitest run",
    "preview": "vite preview"
  },
  "dependencies": {
    "@monaco-editor/react": "^4.7.0",
    "@types/parsimmon": "^1.10.9",
    "allotment": "^1.20.5",
    "monaco-editor": "^0.55.1",
    "parsimmon": "^1.18.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-jss": "^10.10.0",
    "react-markdown": "^9.1.0",
    "usehooks-ts": "^3.1.1"
  },
  "devDependencies": {
    "@types/node": "^20.19.43",
    "@types/react": "^18.3.31",
    "@types/react-dom": "^18.3.7",
    "@typescript-eslint/eslint-plugin": "^8.62.0",
    "@typescript-eslint/parser": "^8.62.0",
    "@vitejs/plugin-react": "^6.0.2",
    "eslint": "^10.5.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^15.0.0",
    "react-github-btn": "^1.4.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "vite-plugin-dts": "^5.0.2",
    "vitest": "^4.1.9"
  }
}
